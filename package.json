{
  "name": "@matrixx0070/sudo-ai",
  "version": "4.1.0",
  "description": "SUDO-AI - Autonomous AI Agent Platform",
  "license": "MIT",
  "bin": {
    "sudo-ai": "./dist/server/cli.js"
  },
  "exports": {
    ".": "./dist/server/cli.js",
    "./cli": "./dist/server/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matrixx0070/sudo-ai.git"
  },
  "bugs": {
    "url": "https://github.com/Matrixx0070/sudo-ai/issues"
  },
  "homepage": "https://github.com/Matrixx0070/sudo-ai#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "!dist/**/*.map",
    "config/sudo-ai.json5",
    "config/.env.example",
    "README.md",
    "BOOTSTRAP.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx src/cli/index.ts start\"",
    "dev:server": "tsx src/cli/index.ts start",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node esbuild.config.cjs",
    "build:cli": "node esbuild.config.cjs",
    "start": "node dist/server/cli.js start",
    "mcp": "node dist/core/gateway/mcp-cli.js",
    "acp": "node dist/core/acp/acp-cli.js",
    "tui:fleetview": "tsx src/tui/fleetview/index.ts",
    "gateway:fleetview": "tsx src/gateway/jsonrpc/index.ts",
    "preview": "pnpm build && pnpm start",
    "doctor": "tsx src/cli/index.ts doctor",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "verify": "pnpm lint && pnpm test && pnpm build",
    "prepublishOnly": "pnpm build && pnpm build:cli && pnpm test",
    "test:fuzz": "vitest run tests/fuzz/",
    "test:soak": "node scripts/soak.ts",
    "build:seal": "bash scripts/build-synth-seal.sh",
    "postinstall": "node -e \"try { require('fs').accessSync('dist/server/cli.js'); console.log('[sudo-ai] postinstall: cli bin present'); } catch(e) { console.log('[sudo-ai] postinstall: building cli for global/dev install'); require('child_process').execSync('pnpm build:cli || npm run build:cli || echo build:cli skipped', {stdio:'inherit'}); }\" ; pnpm build:seal || true",
    "install": "node -e \"console.log('[sudo-ai] post-npm-install: run sudo-ai quickstart or sudo-ai setup (Wave2 wizard) to complete first-time/ongoing setup; sudo-ai chat for real-time TUI; health: curl http://localhost:18900/health')\" || true"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/xai": "^3.0.74",
    "@anthropic-ai/sdk": "^0.81.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@remotion/cli": "^4.0.440",
    "@remotion/renderer": "^4.0.440",
    "@sinclair/typebox": "^0.34.48",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ai": "^6.0.138",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "^12.8.0",
    "busboy": "^1.6.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "discord.js": "^14.25.1",
    "docx": "^9.5.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.41.1",
    "imapflow": "^1.3.1",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "mailparser": "^3.9.8",
    "marked": "^18.0.1",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "openai": "^6.34.0",
    "p-queue": "^9.1.0",
    "phaser": "^3.90.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.440",
    "smol-toml": "^1.6.1",
    "sqlite-vec": "^0.1.7",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "twilio": "^5.13.1",
    "typescript": "^6.0.2",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
