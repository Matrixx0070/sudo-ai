{
  "name": "@matrixx0070/sudo-ai",
  "version": "4.1.7",
  "description": "SUDO-AI - Autonomous AI Agent Platform",
  "author": "Matrixx0070",
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "llm",
    "cli",
    "assistant",
    "self-hosted",
    "anthropic",
    "openai",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "bin": {
    "sudo-ai": "./dist/server/cli.js"
  },
  "exports": {
    ".": "./dist/server/cli.js",
    "./cli": "./dist/server/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matrixx0070/sudo-ai.git"
  },
  "bugs": {
    "url": "https://github.com/Matrixx0070/sudo-ai/issues"
  },
  "homepage": "https://github.com/Matrixx0070/sudo-ai#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "!dist/**/*.map",
    "!dist/**/*.test.js",
    "!dist/**/__tests__/**",
    "config/sudo-ai.json5",
    "config/.env.example",
    "README.md",
    "BOOTSTRAP.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx src/cli/index.ts start\"",
    "dev:server": "tsx src/cli/index.ts start",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node esbuild.config.cjs",
    "build:cli": "node esbuild.config.cjs",
    "start": "node dist/server/cli.js start",
    "mcp": "node dist/core/gateway/mcp-cli.js",
    "acp": "node dist/core/acp/acp-cli.js",
    "tui:fleetview": "tsx src/tui/fleetview/index.ts",
    "gateway:fleetview": "tsx src/gateway/jsonrpc/index.ts",
    "desktop:fleetview": "tsx src/desktop/fleetview/index.ts",
    "eval:agent-bench": "SUDO_LOG_STDERR=1 tsx scripts/agent-bench-run.mts",
    "eval:gate": "tsx scripts/eval-gate.mts",
    "eval:matrix": "SUDO_LOG_STDERR=1 tsx scripts/bench-matrix.mts",
    "preview": "pnpm build && pnpm start",
    "doctor": "tsx src/cli/index.ts doctor",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "smoke:prod-tools": "tsx scripts/smoke/prod-runtime-tools.mts",
    "check:contracts": "tsx scripts/check-brain-contract.mts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "verify": "pnpm lint && pnpm test && pnpm build",
    "prepublishOnly": "pnpm build && pnpm build:cli && pnpm test",
    "test:fuzz": "vitest run tests/fuzz/",
    "test:soak": "node scripts/soak.ts",
    "build:seal": "bash scripts/build-synth-seal.sh",
    "postinstall": "node -e \"const fs=require('fs'),cp=require('child_process');if(!(fs.existsSync('esbuild.config.cjs')&&fs.existsSync('scripts/build-synth-seal.sh')))process.exit(0);if(!fs.existsSync('dist/server/cli.js')){try{cp.execSync('node esbuild.config.cjs',{stdio:'inherit'})}catch(e){}}try{cp.execSync('bash scripts/build-synth-seal.sh',{stdio:'inherit'})}catch(e){}\"",
    "e2e:gateway": "SUDO_E2E=1 tsx scripts/e2e/gateway.mts"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/xai": "^3.0.74",
    "@anthropic-ai/sdk": "^0.81.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@remotion/cli": "^4.0.440",
    "@remotion/renderer": "^4.0.440",
    "@sinclair/typebox": "^0.34.48",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ai": "^6.0.138",
    "better-sqlite3": "^12.8.0",
    "busboy": "^1.6.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "discord.js": "^14.25.1",
    "docx": "^9.5.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.41.1",
    "highlight.js": "^11.11.1",
    "imapflow": "^1.3.1",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "katex": "^0.17.0",
    "mailparser": "^3.9.8",
    "marked": "^18.0.1",
    "mermaid": "^11.16.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "openai": "^6.34.0",
    "p-queue": "^9.1.0",
    "phaser": "^3.90.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.440",
    "sharp": "^0.35.2",
    "smol-toml": "^1.6.1",
    "sqlite-vec": "^0.1.7",
    "three": "^0.183.2",
    "twilio": "^5.13.1",
    "typescript": "^6.0.2",
    "undici": "6.21.3",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "electron": "^33.0.0",
    "kokoro-js": "^1.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "better-sqlite3",
      "electron",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
