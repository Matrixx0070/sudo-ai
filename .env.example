# SUDO-AI Environment Variables
# Copy this file to config/.env and fill in real values.
# config/.env is gitignored and MUST NOT be committed.
# Generate strong tokens: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# ---- Authentication ----
WEB_CHAT_TOKEN=replace-with-strong-random-token
GATEWAY_TOKEN=replace-with-strong-random-token

# ---- LLM providers ----
XAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
XAI_VOICE_API_KEY=

# ---- Integrations ----
TELEGRAM_BOT_TOKEN=
SUDO_AI_DASHBOARD_TOKEN=

# ---- Deployment ----
SUDOAPI_GATEWAY_URL=https://sudoapi.shop
