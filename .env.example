# SUDO-AI Environment Variables
# Copy this file to config/.env and fill in real values.
# config/.env is gitignored and MUST NOT be committed.
# Generate strong tokens: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# ---- Authentication ----
WEB_CHAT_TOKEN=replace-with-strong-random-token
GATEWAY_TOKEN=replace-with-strong-random-token

# ---- LLM providers ----
XAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
XAI_VOICE_API_KEY=
# Pluggable OpenAI-compatible providers (opt-in; JSON array). Adds <name>/<model> prefixes.
# SUDO_CUSTOM_PROVIDERS=[{"name":"openrouter","baseURL":"https://openrouter.ai/api/v1","apiKeyEnv":"OPENROUTER_API_KEY"}]

# ---- Integrations ----
TELEGRAM_BOT_TOKEN=
SUDO_AI_DASHBOARD_TOKEN=

# ---- Opt-in intelligence flags (all default OFF; see docs/api-reference.md#opt-in-intelligence-flags) ----
# SUDO_PREDICTOR_LOOP=1                      # Anticipatory "# HEADS UP" Predictor injection on first turn
# SUDO_PREDICTOR_AUTO_RESOLVE=1              # Resolve expired pending predictions as 'incorrect' (feeds accuracy stats)
# SUDO_FAILURE_LEARNER_DB=1                  # Durable SQLite FailureLearner store (data/mind.db) instead of in-memory
# SUDO_TOOL_OUTCOME_LEARNER=1                # Attach ToolOutcomeLearner to the agent loop (failure learning + hints)
# SUDO_GOAL_PLANNER_SEMANTIC_MAX_PER_RUN=3   # Cap semantic planning calls per run (0 = template-only)
# SUDO_SKILL_FORGE_ASYNC=1                   # Cooperative SkillForge scan (event-loop yields; identical output)
# SUDO_POLICY_AGG_WINDOW_DAYS=30             # Recency window in days for trace-policy aggregates
# SUDO_STUCK_DETECTOR=1                      # Result-aware stuck detection (identical-error streaks: warn 3, abort 5)
# SUDO_PROMPT_CACHE=1                        # Stable-prefix discipline for provider prompt caches (sorted tools, timestamp below boundary)
# SUDO_PROMPT_CACHE_BREAKPOINTS_DISABLE=1    # Skip the Anthropic cache_control breakpoints while keeping the stable prefix
# SUDO_VERIFY_GATE_CACHE=1                   # TTL-LRU over the verify-gate per-tool confidence lookup, so a burst of evaluations of
#                                            #   the same destructive tool skips re-opening audit.db (+ calibration.db). Requires
#                                            #   SUDO_VERIFY_GATE=1. Tunables: _CACHE_TTL_MS (5000, 0=disable), _CACHE_MAX (256 tools)
# SUDO_BRAIN_OAUTH_STREAM_DISABLE=1          # Force legacy buffered generateText for claude-oauth. Default streams claude-oauth completions
#                                            #   so headers land in ~1-2s and the 45s fast-fail headers timer can't false-abort long Opus turns
#                                            #   (the PR #277-#279 trap, on the central brain.call() path). Other providers always buffer.
# SUDO_COST_RATE_ALERT=1                     # Live $/hr cost watchdog: samples api_call_log on a timer, emits a cost_rate_alert hook event on
#                                            #   ceiling (critical) or rolling-baseline deviation (warning). Observable-only, fail-open. Tunables:
#                                            #   _CEILING_USD_PER_HR (10, 0=off), _DEVIATION_PCT (150, 0=off), _MIN_USD_PER_HR (0.5, 0=alert at any spend),
#                                            #   _INTERVAL_MS (600000), _WINDOW_MS (3600000), _COOLDOWN_MS (3600000)
# SUDO_DAILY_BUDGET_USD=5                     # Daily API-spend budget (USD) the system.self-diagnostic + daily-brief cost checks warn (>80%) / fail
#                                            #   (>100%) against. Read at call time; default 5.0 (unset/invalid/zero/negative all fall back — no disable mode). Real spend is summed from
#                                            #   api_call_log for today. Raise it to match an accepted steady-state burn and silence the over-budget status.
# SUDO_WORKFLOWS=1                           # Register meta.run-workflow: deterministic multi-step .yaml workflows (shell + tool steps,
#                                            #   {{prev}} + {{steps.<id>.<field>}} templating, parallel_group fan-out, phase synchronization
#                                            #   barriers, SHA-256 resume journal)
# SUDO_WORKFLOWS_MAX_PARALLEL=4              # Per-engine fan-out cap for parallel_group OR phase members (1 = sequential kill switch). Default 4.
# SUDO_WORKFLOWS_QUEUE=1                     # Register meta.enqueue-workflow + start the cross-workflow scheduler: persistent TaskQueue on
#                                            #   mind.db, TaskExecutor handler for workflow.run, pending runs survive process restarts
# SUDO_WORKFLOWS_QUEUE_CONCURRENT=2          # Max concurrent queued workflow runs (each run also uses SUDO_WORKFLOWS_MAX_PARALLEL internally). Default 2.
# SUDO_WORKFLOWS_QUEUE_POLL_MS=5000          # TaskExecutor poll interval (ms). Minimum 100. Default 5000.

# ---- FleetView TUI (gap #25 slice 2) ----
# Run with: pnpm tui:fleetview  (requires the dashboard server to be up on the host below)
# SUDO_DASHBOARD_HOST=127.0.0.1              # Host the TUI connects to. Default 127.0.0.1.
# SUDO_DASHBOARD_TOKEN=...                   # Bearer token (same one the server prints at boot). REQUIRED unless GATEWAY_TOKEN is set
#                                            #   (the TUI uses GATEWAY_TOKEN as a fallback, matching the dashboard server's own resolution order)
# SUDO_TUI_POLL_MS=1500                      # Poll interval. Minimum 250. Default 1500.
# SUDO_TUI_REQUEST_TIMEOUT_MS=4000           # Per-request timeout. Minimum 500. Default 4000.

# ---- FleetView JSON-RPC gateway (gap #25 slice 3) ----
# Run with: pnpm gateway:fleetview  (NDJSON JSON-RPC 2.0 over stdio; proxies the dashboard HTTP server)
# Reuses SUDO_DASHBOARD_HOST/PORT/TOKEN (+ GATEWAY_TOKEN fallback) from the TUI block above.
# SUDO_GATEWAY_REQUEST_TIMEOUT_MS=4000        # Per-upstream-request timeout. Minimum 500. Default 4000.

# ---- Deployment ----
