// SUDO-AI Configuration — generated by 'sudo-ai setup' (Wave2 full Ink TUI wizard)
// Edit or re-run 'sudo-ai setup' for ongoing changes. Docs: https://github.com/sudo-ai/sudo-ai
// 100x: cross/P1, profiles, learner, KAIROS, SOUL (uncensored owner power), kills via .env
{
  meta: {
    name: "SUDO-AI",
    timezone: 'UTC',
  },
  agents: {
    maxIterations: 150,
    systemPrompt: "You are SUDO-AI. Be helpful, concise, accurate. Owner loyalty per SOUL.",
  },
  models: {
    // Three-tier failover. Sequential failover order is
    // [...primary, fallback] per cli.ts wiring.
    //   1. claude-oauth/claude-opus-4-8   — primary, Max-Plan opus with the
    //      provider's thinking-enable interceptor (#217) injecting a 32k
    //      thinking budget on every request.
    //   2. claude-oauth/claude-sonnet-4-5-20250929 — second-tier within the
    //      same OAuth token. Tried when opus 529's or otherwise fails. Sonnet
    //      doesn't get the thinking-enable injection (gated to opus-4-8+).
    //      NB: the undated `claude-sonnet-4-6` id stalls on the claude.ai OAuth
    //      endpoint (no response headers → undici HeadersTimeoutError, ~99% of
    //      calls); the dated 4-5 id is served reliably. Don't revert to 4-6.
    //   3. ollama/kimi-k2.7-code:cloud   — last-resort outside-anthropic
    //      fallback. K2.7-code (1.04T params, 262k ctx, tools+thinking) on
    //      ollama:cloud. Only runs when both claude-oauth attempts have
    //      failed — covers the "anthropic-wide outage" case where every
    //      OAuth call 529s.
    // cheap + premium pinned to primary so _smartRoute's cheap branch and
    // reasoning-tier branch stay no-ops.
    primary: [
      // xai-oauth example (subscription OAuth Grok via /v1/responses; personalOnly,
      // requires `sudo-ai xai-oauth login` — see docs/providers/xai-oauth.md).
      // Uncomment to add to the failover chain (deploy decision is the operator's):
      // { id: 'xai-oauth/grok-4.3', contextWindow: 256000, maxOutputTokens: 8192, temperature: 0.7 },
      // 2026-07-08 (operator): Fable 5 pinned as DEFAULT model. NB: on the
      // daemon's OAuth token claude-fable-5 currently returns rate_limit_error
      // (verified 3x direct probe) — failover parks it and serves Haiku below;
      // the moment Anthropic enables it on this account it takes over
      // automatically. Haiku 4.5 second = cheap working tier (token saving).
      {
        id: 'claude-oauth/claude-fable-5',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      {
        id: 'claude-oauth/claude-haiku-4-5-20251001',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      {
        id: 'claude-oauth/claude-opus-4-8',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      {
        id: 'claude-oauth/claude-sonnet-4-5-20250929',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      // TEMP 2026-07-07: working API-key tier while claude-oauth is down (token
      // expired 2026-07-06, refresh rejected invalid_grant — needs re-login).
      // The two OAuth tiers above share ONE account, so both fail together;
      // this xAI tier is the only currently-live provider (key verified).
      // Non-reasoning variant: the -fast-reasoning model 400s ("format") on
      // the full agent payload via the AI SDK (reasoning models reject params
      // the SDK sends); non-reasoning is the compatibility-safe agent tier and
      // avoids wasted reasoning tokens. Keep it AFTER the OAuth tiers so a
      // re-authed OAuth reclaims primary automatically. Demote once OAuth is back.
      {
        id: 'google/gemini-2.5-flash',
        contextWindow: 1000000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      // Gemini fallback below the OAuth tiers (reverted from front 2026-07-12 per operator).
      {
        // GW-2 cost-cliff fix: the CHEAP, cache-friendly Grok tier is tried
        // BEFORE grok-4.5. grok-4.5 caches nothing (~10x cost), so landing on it
        // first during a primary outage burned money. Chain order is data: fast
        // tier here, grok-4.5 below as the last-resort escalation.
        // 2026-07-15 (#754): Grok via SuperGrok subscription OAuth on the IR
        // transport (xai-oauth family; XAI_API_KEY expired and was retired).
        // Boot-validated by tests/brain/provider-prefix-boot.test.ts.
        id: 'xai-oauth/grok-4-fast-non-reasoning',
        contextWindow: 256000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      {
        // GW-2: expensive, no-cache escalation — reached only after the fast
        // tier above also fails.
        id: 'xai-oauth/grok-4.5',
        contextWindow: 256000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
    ],
    // TEMP 2026-06-23: swapped kimi-k2.7-code → glm-5.2 while the claude-oauth
    // weekly cap is active (anthropic-ratelimit-unified rejected, resets
    // 2026-06-25T16:00Z). kimi over-explored and could not complete full-cycle
    // drills; glm-5.2 is a stronger code/thinking model on the same ollama:cloud
    // provider (outside Anthropic). Revert to kimi-k2.7-code once Opus is back.
    // contextWindow is glm-5.2's real 1,000,000-token window (ollama /api/show);
    // pair with a larger SUDO_AGENT_WINDOW_SIZE so the loop actually feeds it more
    // history instead of evicting reads at the default 12-message window.
    fallback: {
      id: 'ollama/glm-5.2:cloud',
      contextWindow: 1000000,
      maxOutputTokens: 8192,
      temperature: 0.7,
    },
    cheap: 'claude-oauth/claude-fable-5',
    premium: 'claude-oauth/claude-fable-5',
    embedding: { id: 'openai/text-embedding-3-small', dims: 1536 },
  },
  auth: {
    xai: { envKey: 'XAI_API_KEY' },
    openai: { envKey: 'OPENAI_API_KEY' },
    anthropic: { envKey: 'ANTHROPIC_API_KEY' },
    google: { envKey: 'GOOGLE_API_KEY' },
  },
  channels: {
    telegram: { enabled: true, tokenEnvKey: 'TELEGRAM_BOT_TOKEN', allowedUsers: ['8087386717'] },
    whatsapp: { enabled: false, sessionPath: 'data/whatsapp', allowedJids: [] },
    discord: { enabled: false, tokenEnvKey: 'DISCORD_BOT_TOKEN', allowedChannelIds: [] },
  },
  tools: {
    disabled: [],
    browser: { headless: true, timeoutMs: 30000 },
  },
  cron: { jobs: [] },
  gateway: {
    enabled: true,
    port: 18900,
    allowedHosts: ['localhost', '127.0.0.1'],
    secretEnvKey: 'GATEWAY_TOKEN',
  }
  
    // 100x P1: cross-platform IComputerUse enabled (exec/file/GUI/desktop/browser on 3OS + learner on outcomes). Set SUDO_CROSS...=1 to disable.
  
    // 100x: multi-profile isolation enabled (see data/profiles/).
  
    // 100x: ToolOutcomeLearner + self-improvement active on tools/control.
}
