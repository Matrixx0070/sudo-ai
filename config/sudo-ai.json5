// SUDO-AI Configuration — generated by 'sudo-ai setup' (Wave2 full Ink TUI wizard)
// Edit or re-run 'sudo-ai setup' for ongoing changes. Docs: https://github.com/sudo-ai/sudo-ai
// 100x: cross/P1, profiles, learner, KAIROS, SOUL (uncensored owner power), kills via .env
{
  meta: {
    name: "SUDO-AI",
    timezone: 'UTC',
  },
  agents: {
    maxIterations: 150,
    systemPrompt: "You are SUDO-AI. Be helpful, concise, accurate. Owner loyalty per SOUL.",
  },
  models: {
    primary: [
      {
        // Claude.ai Max subscription via PKCE OAuth (no API key needed).
        // Connect with: `pnpm tsx src/cli/index.ts claude-oauth login`.
        id: 'claude-oauth/claude-opus-4-8',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
    ],
    fallback: {
      // Claude.ai Sonnet 4.5 via the same OAuth — kicks in if Opus 4.8 is
      // rate-limited (Anthropic enforces lower per-account quotas on Opus tier).
      id: 'claude-oauth/claude-sonnet-4-5-20250929',
      contextWindow: 200000,
      maxOutputTokens: 4096,
      temperature: 0.7,
    },
    embedding: { id: 'openai/text-embedding-3-small', dims: 1536 },
  },
  auth: {
    xai: { envKey: 'XAI_API_KEY' },
    openai: { envKey: 'OPENAI_API_KEY' },
    anthropic: { envKey: 'ANTHROPIC_API_KEY' },
    google: { envKey: 'GOOGLE_API_KEY' },
  },
  channels: {
    telegram: { enabled: true, tokenEnvKey: 'TELEGRAM_BOT_TOKEN', allowedUsers: ['8087386717'] },
    whatsapp: { enabled: false, sessionPath: 'data/whatsapp', allowedJids: [] },
    discord: { enabled: false, tokenEnvKey: 'DISCORD_BOT_TOKEN', allowedChannelIds: [] },
  },
  tools: {
    disabled: [],
    browser: { headless: true, timeoutMs: 30000 },
  },
  cron: { jobs: [] },
  gateway: {
    enabled: true,
    port: 18900,
    allowedHosts: ['localhost', '127.0.0.1'],
    secretEnvKey: 'GATEWAY_TOKEN',
  }
  
    // 100x P1: cross-platform IComputerUse enabled (exec/file/GUI/desktop/browser on 3OS + learner on outcomes). Set SUDO_CROSS...=1 to disable.
  
    // 100x: multi-profile isolation enabled (see data/profiles/).
  
    // 100x: ToolOutcomeLearner + self-improvement active on tools/control.
}
