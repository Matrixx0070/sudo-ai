// SUDO-AI Configuration — generated by 'sudo-ai setup' (Wave2 full Ink TUI wizard)
// Edit or re-run 'sudo-ai setup' for ongoing changes. Docs: https://github.com/sudo-ai/sudo-ai
// 100x: cross/P1, profiles, learner, KAIROS, SOUL (uncensored owner power), kills via .env
{
  meta: {
    name: "SUDO-AI",
    timezone: 'UTC',
  },
  agents: {
    maxIterations: 150,
    systemPrompt: "You are SUDO-AI. Be helpful, concise, accurate. Owner loyalty per SOUL.",
  },
  models: {
    // Three-tier failover. Sequential failover order is
    // [...primary, fallback] per cli.ts wiring.
    //   1. claude-oauth/claude-opus-4-8   — primary, Max-Plan opus with the
    //      provider's thinking-enable interceptor (#217) injecting a 32k
    //      thinking budget on every request.
    //   2. claude-oauth/claude-sonnet-4-5-20250929 — second-tier within the
    //      same OAuth token. Tried when opus 529's or otherwise fails. Sonnet
    //      doesn't get the thinking-enable injection (gated to opus-4-8+).
    //      NB: the undated `claude-sonnet-4-6` id stalls on the claude.ai OAuth
    //      endpoint (no response headers → undici HeadersTimeoutError, ~99% of
    //      calls); the dated 4-5 id is served reliably. Don't revert to 4-6.
    //   3. ollama/kimi-k2.7-code:cloud   — last-resort outside-anthropic
    //      fallback. K2.7-code (1.04T params, 262k ctx, tools+thinking) on
    //      ollama:cloud. Only runs when both claude-oauth attempts have
    //      failed — covers the "anthropic-wide outage" case where every
    //      OAuth call 529s.
    // cheap + premium pinned to primary so _smartRoute's cheap branch and
    // reasoning-tier branch stay no-ops.
    primary: [
      {
        id: 'claude-oauth/claude-opus-4-8',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
      {
        id: 'claude-oauth/claude-sonnet-4-5-20250929',
        contextWindow: 200000,
        maxOutputTokens: 8192,
        temperature: 0.7,
      },
    ],
    // TEMP 2026-06-23: swapped kimi-k2.7-code → glm-5.2 while the claude-oauth
    // weekly cap is active (anthropic-ratelimit-unified rejected, resets
    // 2026-06-25T16:00Z). kimi over-explored and could not complete full-cycle
    // drills; glm-5.2 is a stronger code/thinking model on the same ollama:cloud
    // provider (outside Anthropic). Revert to kimi-k2.7-code once Opus is back.
    fallback: {
      id: 'ollama/glm-5.2:cloud',
      contextWindow: 262144,
      maxOutputTokens: 8192,
      temperature: 0.7,
    },
    cheap: 'claude-oauth/claude-opus-4-8',
    premium: 'claude-oauth/claude-opus-4-8',
    embedding: { id: 'openai/text-embedding-3-small', dims: 1536 },
  },
  auth: {
    xai: { envKey: 'XAI_API_KEY' },
    openai: { envKey: 'OPENAI_API_KEY' },
    anthropic: { envKey: 'ANTHROPIC_API_KEY' },
    google: { envKey: 'GOOGLE_API_KEY' },
  },
  channels: {
    telegram: { enabled: true, tokenEnvKey: 'TELEGRAM_BOT_TOKEN', allowedUsers: ['8087386717'] },
    whatsapp: { enabled: false, sessionPath: 'data/whatsapp', allowedJids: [] },
    discord: { enabled: false, tokenEnvKey: 'DISCORD_BOT_TOKEN', allowedChannelIds: [] },
  },
  tools: {
    disabled: [],
    browser: { headless: true, timeoutMs: 30000 },
  },
  cron: { jobs: [] },
  gateway: {
    enabled: true,
    port: 18900,
    allowedHosts: ['localhost', '127.0.0.1'],
    secretEnvKey: 'GATEWAY_TOKEN',
  }
  
    // 100x P1: cross-platform IComputerUse enabled (exec/file/GUI/desktop/browser on 3OS + learner on outcomes). Set SUDO_CROSS...=1 to disable.
  
    // 100x: multi-profile isolation enabled (see data/profiles/).
  
    // 100x: ToolOutcomeLearner + self-improvement active on tools/control.
}
