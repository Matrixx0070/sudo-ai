# =============================================================================
# SUDO-AI v5 — Environment Variables Template
# =============================================================================
# Copy this file to config/.env and fill in the real values.
# NEVER commit config/.env — it contains live secrets.
# Keys marked <your-...> require a real secret value.
# Keys with a plain default value are safe to use as-is.
# =============================================================================

# ---------------------------------------------------------------------------
# Brain / Primary Provider — xAI Grok
# ---------------------------------------------------------------------------
XAI_API_KEY=<your-xai-api-key>
XAI_VOICE_API_KEY=<your-xai-voice-api-key>
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast-reasoning
XAI_FAST_MODEL=grok-4-fast-non-reasoning
XAI_REASONING_MODEL=grok-4.20-0309-reasoning

# ---------------------------------------------------------------------------
# Brain / Secondary Providers
# ---------------------------------------------------------------------------
# Groq — FREE Whisper STT (28,800 sec/day free). Get key: console.groq.com
GROQ_API_KEY=<your-groq-api-key>

# OpenAI — image generation + whisper fallback
OPENAI_API_KEY=<your-openai-api-key>

# Google Gemini — image generation
GEMINI_API_KEY=<your-gemini-api-key>

# Anthropic — subagent models / Claude proxy
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_CHAT_ID=<your-chat-id>

# ---------------------------------------------------------------------------
# Web Chat Server
# ---------------------------------------------------------------------------
WEB_CHAT_HOST=0.0.0.0
# WEB_CHAT_PORT removed — chat now served on GATEWAY_PORT (default 18900) at /chat
# Web chat serves on GATEWAY_PORT at /chat path — no separate port needed.
WEB_CHAT_ENABLED=true
# Web chat token auth — leave empty to disable, set a value to require ?token=VALUE
WEB_CHAT_TOKEN=

# ---------------------------------------------------------------------------
# Claude CLI / Proxy
# ---------------------------------------------------------------------------
CLAUDE_CLI_ENABLED=false
CLAUDE_PROXY_PORT=3002

# ---------------------------------------------------------------------------
# Admin Dashboard
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SUDO_AI_DASHBOARD_TOKEN=<your-dashboard-token>

# ---------------------------------------------------------------------------
# Gateway / API Server
# ---------------------------------------------------------------------------
GATEWAY_PORT=18800

# ---------------------------------------------------------------------------
# Voice / TTS
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>

# Sherpa ONNX — local offline TTS (optional)
SHERPA_ONNX_RUNTIME_DIR=/opt/sherpa-onnx
SHERPA_ONNX_MODEL_DIR=/opt/sherpa-onnx/models

# ---------------------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------------------
# Notion
NOTION_API_KEY=<your-notion-api-key>

# Google Places
GOOGLE_PLACES_API_KEY=<your-google-places-api-key>

# Trello
TRELLO_API_KEY=<your-trello-api-key>
TRELLO_TOKEN=<your-trello-token>

# YouTube
YOUTUBE_CHANNEL_ID=<your-youtube-channel-id>

# Social posting — Mastodon
MASTODON_INSTANCE=<your-mastodon-instance-url>
MASTODON_ACCESS_TOKEN=<your-mastodon-access-token>

# Social posting — Twitter / X (OAuth2)
TWITTER_OAUTH2_TOKEN=<your-twitter-oauth2-token>

# YouTube OAuth (for community posts)
YOUTUBE_OAUTH_TOKEN=<your-youtube-oauth-token>
