# SUDO-AI Environment Variables
# Copy this file to config/.env and fill in real values.
# config/.env is gitignored and MUST NOT be committed.
# Generate strong tokens: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# ---- Authentication ----
WEB_CHAT_TOKEN=replace-with-strong-random-token
GATEWAY_TOKEN=replace-with-strong-random-token

# ---- LLM providers ----
XAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
XAI_VOICE_API_KEY=
# Pluggable OpenAI-compatible providers (opt-in; JSON array). Adds <name>/<model> prefixes.
# SUDO_CUSTOM_PROVIDERS=[{"name":"openrouter","baseURL":"https://openrouter.ai/api/v1","apiKeyEnv":"OPENROUTER_API_KEY"}]

# ---- Integrations ----
TELEGRAM_BOT_TOKEN=
SUDO_AI_DASHBOARD_TOKEN=

# ---- Google Drive memory substrate (Drive roadmap; default OFF; see docs/gdrive-setup.md) ----
# SUDO_GDRIVE=1                              # Master switch for the Drive foundation layer
# GDRIVE_AUTH_MODE=service_account           # service_account (default) | oauth (loopback; never oob)
# GOOGLE_APPLICATION_CREDENTIALS=            # ABSOLUTE path to the service-account JSON key — keep OUTSIDE the repo, chmod 0600
# GDRIVE_ROOT_FOLDER_ID=                     # fileId of the shared "sudo-ai" Drive folder (last segment of its URL)
# GDRIVE_OAUTH_CLIENT_FILE=                  # oauth mode: OAuth client-secret JSON path
# GDRIVE_OAUTH_TOKEN_FILE=                   # oauth mode: token store written by the loopback flow (0600)
# GDRIVE_RPS=5                               # Token-bucket sustained req/s (shared by all Drive/Sheets calls)
# GDRIVE_BURST=10                            # Token-bucket burst capacity
# GDRIVE_MAX_RETRIES=5                       # Max retries on 403-rate/429/5xx/network (exp backoff + jitter)
# GDRIVE_HEARTBEAT_MS=300000                 # ops/heartbeat.json cadence (min 10000)
# BRAIN_HMAC_KEY_PATH=                       # manifest signing key (F17): openssl rand -hex 32 > <path> && chmod 600 <path>; NEVER commit/sync
# BRAIN_ENC_KEY_PATH=                        # zone-1 AES-256-GCM key (F29): same generation; only needed when zone-1 memories exist
# SUDO_GDRIVE_CHECKPOINT_MS=21600000         # F2 brain checkpoint cadence (default 6h, min 60000)
# SUDO_GDRIVE_DRILL_MS=604800000             # F2 restore-drill cadence (default weekly, min 60000)
# SUDO_GDRIVE_INBOX_MS=60000                 # F1 knowledge-inbox poll cadence (min 10000)
# GDRIVE_PRINCIPAL_EMAILS=                   # F16 comma-separated owner emails (trust-tier 'principal' writers)
# GDRIVE_CANARY_CONFIG=                      # F19 canary fileIds+markers JSON (default data/gdrive/canaries.json); NEVER in Drive
# GDRIVE_QUARANTINE_THRESHOLD=0.5            # F18 risk threshold (0.1-0.9); also phone-tunable via control panel
# SUDO_GDRIVE_REPORT_CRON=55 23 * * *        # F3 daily self-report schedule (SUDO_SCHEDULER_TZ)
# SUDO_GDRIVE_ATLAS_CRON=15 0 * * *          # F30 brain-atlas regeneration schedule
# SUDO_GDRIVE_PANEL_MS=30000                 # F7 control-panel poll cadence (min 10000)
# SUDO_GDRIVE_COMMENTS_MS=120000             # F6 comments poll cadence (min 30000)
# SUDO_GDRIVE_CHANGES_MS=60000               # F22 changes-feed sweep cadence (min 30000)
# SUDO_GDRIVE_REVALIDATE_CRON=35 0 * * *     # F23 nightly belief re-validation
# SUDO_GDRIVE_MIRROR_MS=3600000              # F37 mirror sweep cadence (per-ref cadence inside; min 300000)
# GDRIVE_MIRROR_CONFIG=                      # F37 refs JSON (default config/gdrive-mirror.json): {refs:[{name,url,cadenceHours}]}
# SUDO_GDRIVE_DREAM_CRON=30 2 * * *          # F12 dream cycle (re-derive/confirm/reconcile/agenda)
# SUDO_GDRIVE_FREEZE_CRON=50 2 * * *         # F11 deep-freeze eviction sweep
# SUDO_GDRIVE_FREEZE_AGE_DAYS=30             # F11 episodic day-logs older than this evict to Drive
# SUDO_GDRIVE_SNAPSHOT_CRON=10 3 * * *       # F28 embedding-index snapshot
# SUDO_GDRIVE_BLACKBOARD_MS=300000           # F14 blackboard beat cadence (min 60000)
# SUDO_GDRIVE_CURIOSITY_CRON=45 3 * * *      # F38 curiosity drain (dream window; never preempts principal work)
# SUDO_GDRIVE_CURIOSITY_BUDGET=5             # F38 hard daily research budget
# SUDO_GDRIVE_FLIGHT_RECORDER=1              # F10 run bundles on session:end (opt-in until validated live)
# SUDO_GDRIVE_FLIGHT_ALL=1                   # F10 also bundle successful runs (default: incidents only)
# SUDO_GDRIVE_USER_FILES=1                   # F5 gated user-file tools (gdrive.list/read/write-user-file; owner-only; never touches the memory tree)
# SUDO_GDRIVE_AUTOHIBERNATE=1                # F35 auto-hibernate long agent runs to Drive at iteration boundaries
# SUDO_GDRIVE_AUTOHIBERNATE_EVERY=25         # iterations between auto-hibernation checkpoints (min 5)

# ---- Opt-in intelligence flags (all default OFF; see docs/api-reference.md#opt-in-intelligence-flags) ----
# SUDO_PREDICTOR_LOOP=1                      # Anticipatory "# HEADS UP" Predictor injection on first turn
# SUDO_PREDICTOR_AUTO_RESOLVE=1              # Resolve expired pending predictions as 'incorrect' (feeds accuracy stats)
# SUDO_FAILURE_LEARNER_DB=1                  # Durable SQLite FailureLearner store (data/mind.db) instead of in-memory
# SUDO_TOOL_OUTCOME_LEARNER=1                # Attach ToolOutcomeLearner to the agent loop (failure learning + hints)
# SUDO_GOAL_PLANNER_SEMANTIC_MAX_PER_RUN=3   # Cap semantic planning calls per run (0 = template-only)
# SUDO_SKILL_FORGE_ASYNC=1                   # Cooperative SkillForge scan (event-loop yields; identical output)
# SUDO_POLICY_AGG_WINDOW_DAYS=30             # Recency window in days for trace-policy aggregates
# SUDO_STUCK_DETECTOR=1                      # Result-aware stuck detection (identical-error streaks: warn 3, abort 5)
# SUDO_PROMPT_CACHE=1                        # Stable-prefix discipline for provider prompt caches (sorted tools, timestamp below boundary)
# SUDO_PROMPT_CACHE_BREAKPOINTS_DISABLE=1    # Skip the Anthropic cache_control breakpoints while keeping the stable prefix
# SUDO_VERIFY_GATE_CACHE=1                   # TTL-LRU over the verify-gate per-tool confidence lookup, so a burst of evaluations of
#                                            #   the same destructive tool skips re-opening audit.db (+ calibration.db). Requires
#                                            #   SUDO_VERIFY_GATE=1. Tunables: _CACHE_TTL_MS (5000, 0=disable), _CACHE_MAX (256 tools)
# SUDO_BRAIN_OAUTH_STREAM_DISABLE=1          # Force legacy buffered generateText for claude-oauth. Default streams claude-oauth completions
#                                            #   so headers land in ~1-2s and the 45s fast-fail headers timer can't false-abort long Opus turns
#                                            #   (the PR #277-#279 trap, on the central brain.call() path). Other providers always buffer.
# SUDO_COST_RATE_ALERT=1                     # Live $/hr cost watchdog: samples api_call_log on a timer, emits a cost_rate_alert hook event on
#                                            #   ceiling (critical) or rolling-baseline deviation (warning). Observable-only, fail-open. Tunables:
#                                            #   _CEILING_USD_PER_HR (10, 0=off), _DEVIATION_PCT (150, 0=off), _MIN_USD_PER_HR (0.5, 0=alert at any spend),
#                                            #   _INTERVAL_MS (600000), _WINDOW_MS (3600000), _COOLDOWN_MS (3600000)
# SUDO_DAILY_BUDGET_USD=5                     # Daily API-spend budget (USD) the system.self-diagnostic + daily-brief cost checks warn (>80%) / fail
#                                            #   (>100%) against. Read at call time; default 5.0 (unset/invalid/zero/negative all fall back — no disable mode). Real spend is summed from
#                                            #   api_call_log for today. Raise it to match an accepted steady-state burn and silence the over-budget status.
# SUDO_WORKFLOWS=1                           # Register meta.run-workflow: deterministic multi-step .yaml workflows (shell + tool steps,
#                                            #   {{prev}} + {{steps.<id>.<field>}} templating, parallel_group fan-out, phase synchronization
#                                            #   barriers, SHA-256 resume journal)
# SUDO_WORKFLOWS_MAX_PARALLEL=4              # Per-engine fan-out cap for parallel_group OR phase members (1 = sequential kill switch). Default 4.
# SUDO_WORKFLOWS_QUEUE=1                     # Register meta.enqueue-workflow + start the cross-workflow scheduler: persistent TaskQueue on
#                                            #   mind.db, TaskExecutor handler for workflow.run, pending runs survive process restarts
# SUDO_WORKFLOWS_QUEUE_CONCURRENT=2          # Max concurrent queued workflow runs (each run also uses SUDO_WORKFLOWS_MAX_PARALLEL internally). Default 2.
# SUDO_WORKFLOWS_QUEUE_POLL_MS=5000          # TaskExecutor poll interval (ms). Minimum 100. Default 5000.

# ---- FleetView TUI (gap #25 slice 2) ----
# Run with: pnpm tui:fleetview  (requires the dashboard server to be up on the host below)
# SUDO_DASHBOARD_HOST=127.0.0.1              # Host the TUI connects to. Default 127.0.0.1.
# SUDO_DASHBOARD_TOKEN=...                   # Bearer token (same one the server prints at boot). REQUIRED unless GATEWAY_TOKEN is set
#                                            #   (the TUI uses GATEWAY_TOKEN as a fallback, matching the dashboard server's own resolution order)
# SUDO_TUI_POLL_MS=1500                      # Poll interval. Minimum 250. Default 1500.
# SUDO_TUI_REQUEST_TIMEOUT_MS=4000           # Per-request timeout. Minimum 500. Default 4000.

# ---- FleetView JSON-RPC gateway (gap #25 slice 3) ----
# Run with: pnpm gateway:fleetview  (NDJSON JSON-RPC 2.0 over stdio; proxies the dashboard HTTP server)
# Reuses SUDO_DASHBOARD_HOST/PORT/TOKEN (+ GATEWAY_TOKEN fallback) from the TUI block above.
# SUDO_GATEWAY_REQUEST_TIMEOUT_MS=4000        # Per-upstream-request timeout. Minimum 500. Default 4000.

# ---- Admin REST API (/api/admin/*) ----
# Mounts the AdminRouter on the gateway (dashboard/cost stats, models cost, logs, tools, sessions, etc.).
# Default OFF; fail-closed and Bearer token-gated. Gateway binds 127.0.0.1 only.
# SUDO_ADMIN_API=1                            # Enable. If set but NO admin token is configured, the registrar REFUSES to mount (fail-closed)
#                                            #   and logs a loud error — /api/admin/* stays 404. Off = byte-identical to before (404).
# SUDO_AI_DASHBOARD_TOKEN=...                 # Canonical admin Bearer token (GATEWAY_TOKEN accepted as a fallback). Use 32+ bytes of entropy.
# SUDO_ADMIN_API_DANGER=1                     # SECOND opt-in for irreversible routes: POST /api/admin/service/{restart,stop} (process.exit) and
#                                            #   /api/admin/system/{backup,restore} (restore OVERWRITES live DBs). Without it, those return 403 even when authed.

# ---- Background shell tools (gap #10) ----
# Registers system.shell.start / .poll / .kill — run a long command in the background, poll incremental output, kill it.
# Default OFF. Reuses the SAME approval gate (EXEC_APPROVAL_MODE/EXEC_APPROVAL_WAIT_MS) and sandbox as system.exec.
# SUDO_BG_SHELL=1                             # Enable the tool family. When unset, the tools are not registered (no registry/reaper).
# SUDO_BG_SHELL_MAX_CONCURRENT=8              # Max concurrently-running background shells (anti-fork-bomb). Default 8.
# SUDO_BG_SHELL_BUFFER_BYTES=262144           # Per-stream ring-buffer cap (bytes); output past it is dropped oldest-first. Default 256KB.
# SUDO_BG_SHELL_CPU_SECONDS=3600              # Raises the sandbox's 30s CPU ulimit for bg shells (else long shells are SIGKILLed). Default 3600.

# ---- Native tool correction (gap #7) ----
# When an MCP tool call fails, optionally auto-correct to the SUDO-AI native equivalent and re-dispatch.
# SUDO_NATIVE_TOOL_CORRECTION_FALLBACK=1      # Enable the MCP-failure fallback (default OFF — MCP failures return unchanged).
#                                            #   Fail-open: any error in the correction path returns the original MCP failure.
#                                            #   Maps e.g. shell_execute->system.exec, filesystem_read_file->coder.read-file, code_search->coder.grep.
# SUDO_NATIVE_TOOL_CORRECTION=0              # Hard-disable correction entirely (default ON within the module; the FALLBACK flag gates the wiring).
#                                            #   Note: =0 OVERRIDES FALLBACK=1 — it disables all correction even when the fallback is enabled.

# ---- Semantic memory compaction (gap #8) ----
# At the end of each auto-dream cycle, collapse same-source NEAR-DUPLICATE chunks (cosine >= 0.92) into one
# canonical row. NOTE: this DELETES the younger duplicate (summing applied_count into the keeper) — a real
# mutation of mind.db chunks. Evergreen-protected, same-source-only, capped 500/run, fail-open.
# SUDO_SEMANTIC_COMPACT=1                     # Enable. Off = the chunks table is never touched (no ALTER, no deletes). Requires OPENAI_API_KEY (no-op without).
#                                            #   First run adds applied_count + embedding_json columns to chunks (additive, idempotent).

# ---- Completion verification (phantom-completion check) ----
# After each turn, run a cheap NO-LLM heuristic check on the final response (placeholder / truncated /
# too-short / does-not-address-the-request) and surface a confidence signal on the run result.
# SUDO_COMPLETION_VERIFY=1                    # Enable. Default OFF (byte-identical when off). Observable-only — NEVER
#                                            #   alters the response; attaches result.completionVerification {passed, confidence,
#                                            #   failedChecks} and logs a warning on a likely phantom completion. Fail-open. No API cost.
#                                            #   Complements the LLM CriticPass (SUDO_VERIFY_GATE) and preventive SUDO_AUTO_PLAN.

# ---- Execution trace capture + retention (replay / regression / eval) ----
# Records raw tool/brain I/O per session to data/traces.db so a run can be replayed or regression-diffed.
# Inspect a captured session:  sudo-ai replay <sessionId> [--json]
# SUDO_TRACE_CAPTURE=1                        # Store raw args/result + prompt/response/sampling (DEFAULT ON — set in
#                                            #   ecosystem.config.cjs). Off = only fact-of-call + token usage kept (sessions are not replayable).
# SUDO_TRACE_CAPTURE_MAX_BYTES=16384         # Per-field size cap for captured raw payloads. Default 16KB.
# SUDO_TRACE_RETENTION_DAYS=30               # Prune traces older than N days (by created_at), at boot + daily. 0 = no age pruning. Default 30.
# SUDO_TRACE_MAX_ROWS=200000                 # Hard cap — prune oldest rows beyond this. 0 = no row cap. Default 200000.

# ---- Gateway response cache (/v1/chat/completions) ----
# Cache non-streaming completions PER SESSION so a repeated identical request (same client +
# model + last user message) within a 60s TTL returns the prior response and skips a full agent run.
# SUDO_RESPONSE_CACHE=1                       # Enable. Default OFF (byte-identical when off). Per-session keyed
#                                            #   (no cross-client sharing); streaming responses are never cached; fail-open.
#                                            #   60s TTL, 200-entry LRU. Best for API retries/idempotent polling; opt-in because the agent
#                                            #   is stateful: context mutations (memory updates, tool results) within the TTL window are
#                                            #   NOT reflected in cached responses. Cache hits/misses surface in GET /health stats.

# ---- Deployment ----

# ---------------------------------------------------------------------------
# Brain / Provider details (models + optional providers)
# ---------------------------------------------------------------------------
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast-reasoning
XAI_FAST_MODEL=grok-4-fast-non-reasoning
XAI_REASONING_MODEL=grok-4.20-0309-reasoning
# Groq — FREE Whisper STT (28,800 sec/day free). Get key: console.groq.com
GROQ_API_KEY=
# Anthropic — subagent models
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Channels / Servers
# ---------------------------------------------------------------------------
TELEGRAM_CHAT_ID=
GATEWAY_PORT=18900
WEB_CHAT_HOST=0.0.0.0
# Web chat serves on GATEWAY_PORT at /chat path — no separate port needed.
WEB_CHAT_ENABLED=true

# ---------------------------------------------------------------------------
# WhatsApp (opt-in, OFF by default)
# ---------------------------------------------------------------------------
# WARNING: the WhatsApp channel uses Baileys (unofficial WhatsApp Web), which
# is against WhatsApp's Terms of Service and may get your number banned. It is
# disabled unless you explicitly opt in. Use at your own risk and only with
# consented recipients.
#   SUDO_WHATSAPP_ENABLE=1   # required to opt in
#   WHATSAPP_TOKEN=...       # activation flag (also required)
SUDO_WHATSAPP_ENABLE=0
WHATSAPP_TOKEN=
# Optional comma-separated allowlist of WhatsApp JIDs that may message the agent
WHATSAPP_ALLOWED_JIDS=

# ---------------------------------------------------------------------------
# Voice / TTS — Sherpa ONNX local offline TTS (optional)
# ---------------------------------------------------------------------------
SHERPA_ONNX_RUNTIME_DIR=/opt/sherpa-onnx
SHERPA_ONNX_MODEL_DIR=/opt/sherpa-onnx/models

# ---------------------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------------------
NOTION_API_KEY=
GOOGLE_PLACES_API_KEY=
TRELLO_API_KEY=
TRELLO_TOKEN=
YOUTUBE_CHANNEL_ID=
MASTODON_INSTANCE=
MASTODON_ACCESS_TOKEN=
TWITTER_OAUTH2_TOKEN=
# YouTube OAuth (for community posts)
YOUTUBE_OAUTH_TOKEN=
